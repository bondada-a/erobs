# Minimal test build to verify Ubuntu 24.04 + ROS2 Jazzy base layers
# Run: docker build -f docker/jazzy/Dockerfile.test -t erobs-jazzy-test .
FROM osrf/ros:jazzy-desktop-full

RUN echo 'APT::Sandbox::User "root";' > /etc/apt/apt.conf.d/99sandboxdisable

# Test that key ROS2 Jazzy packages install correctly
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    python3-pip \
    python3-venv \
    python3-colcon-common-extensions \
    python3-vcstool \
    ros-${ROS_DISTRO}-rclpy \
    ros-${ROS_DISTRO}-ur \
    ros-${ROS_DISTRO}-moveit \
    ocl-icd-libopencl1 \
    opencl-headers \
    ocl-icd-opencl-dev \
    && apt-get clean -y && rm -rf /var/lib/apt/lists/*

# Verify ROS2 Jazzy is set up correctly
RUN /bin/bash -c "source /opt/ros/jazzy/setup.bash && \
    echo 'ROS_DISTRO: \$ROS_DISTRO' && \
    python3 -c 'import rclpy; print(\"rclpy OK\")' && \
    echo 'All base dependencies verified successfully'"
