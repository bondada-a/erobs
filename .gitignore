# Debug outputs (keep root clean)
*.gv
frames_*.pdf
frames_*.gv

# LaTeX build artifacts
*.aux
*.fls
*.fdb_latexmk
*.synctex.gz
*.out

# ROS bag recordings (can be large)
*.bag
*.db3
*.mcap
rosbag2_*/
# Survey bags are recorded at the repo root (run_survey.py --bag-out). Anchor to
# root so this doesn't swallow scripts/survey_mapping/ (the tooling itself).
/survey_*/
src/moveit_task_constructor/
yolov8n.pt

# Point cloud / mesh outputs from survey mapping (large, regenerable from bags)
*.ply
*.pcd

# OMC / Claude Code state
.claude/worktrees/
.claude/*.backup*
state/
**/.omc/

# Per-dev local Claude Code state — not shared.
.claude/settings.json
.claude/settings.local.json
.claude/memory.db
# Keep .claude/skills/omc-reference/ tracked (pre-existing) and robot-operation/
# (project-owned skill pointing at src/beambot/beambot/agent/robot_operation.md);
# ignore any other locally-installed skills.
.claude/skills/*/
!.claude/skills/omc-reference/
!.claude/skills/robot-operation/

# Training data (large files)
src/beambot/data/spincoater_training/
src/beambot/data/yolo_dataset/spincoater_obb/

# Understand-Anything generated knowledge graph (per-dev tooling output)
.understand-anything/

# VLM service (large local models / venv — not shared via git)
vlm_service/

# Planning-latency investigation scratch (probe scripts, plots, diagnostic notes — local only)
latency_analysis/

# Debug capture images (keep root clean)
marker_sheet_detections*.png
