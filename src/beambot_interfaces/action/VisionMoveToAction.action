# Goal
int32 tag_id                # ArUco marker ID to detect (used when detection_type="marker")
int32 sample_index          # Sample number to select (for contour detection, 1-indexed, default: 1)
                            # Objects are sorted left-to-right, top-to-bottom (reading order)
float64 timeout             # Detection timeout in seconds (default: 5.0)
string poses_json           # Pose definitions from task (unused for vision)
string detection_type       # Detection method: "marker" (default), "circle", "contour", "sample_roi"
float64 z_offset            # Z offset for approach (0 = use gripper default)
float64[] scan_positions_flat  # Multi-position mode: Flattened joint poses [j1..j6, j1..j6, ...]
int32 num_scan_positions       # Number of scan positions (0 = single-position mode)
bool detect_only            # If true, detect and return position without moving
string offset_direction     # Direction offset from approach pose (e.g. "right", "left", "forward")
                            # Uses same names as DIRECTION_VECTORS (flange frame). Empty = no offset.
float64 offset_distance     # Distance in meters for offset_direction (default: 0.0)
float64 marker_offset_x     # Offset from marker in marker local X (meters). 0 = use class default.
float64 marker_offset_y     # Offset from marker in marker local Y (meters). 0 = use class default.
float64 marker_offset_z     # Offset from marker in marker local Z (meters). 0 = none.
string ik_frame             # IK frame override (e.g. "pipette_tip_link", "epick_tip").
                            # Empty = auto-detect from TF. Set by orchestrator after tool exchange
                            # to avoid stale TF auto-detection.
string strategy             # Pickup strategy for sample_roi: "center", "farthest_edge" (default),
                            # "nearest_edge", "farthest_corner", "nearest_corner".
                            # Only used when detection_type="sample_roi".
float64 edge_inset_mm       # Distance inward from edge toward center (mm). Default: 4.0.
                            # Only used when detection_type="sample_roi".
---
# Result
bool success
string error_message
float64[] detected_position    # [x, y, z] in base_link frame (populated when detect_only=true)
float64[] detected_orientation # [x, y, z, w] quaternion in base_link (populated when detect_only=true)
---
# Feedback
