# Goal
string gripper_group        # MoveIt group name (from config): "hande_gripper", "epick_gripper", ""
string gripper_states_json  # JSON dict of semantic states: {"grasp": "hande_closed", "release": "hande_open"}
string pick_approach        # Approach pose name
string pick_target          # Grasp pose name
string place_approach       # Place approach pose name
string place_target         # Place target pose name
string poses_json           # Pose definitions from task
string constraints_json     # Optional: JSON path constraints (empty = none)
---
# Result
bool success
string error_message
---
# Feedback
