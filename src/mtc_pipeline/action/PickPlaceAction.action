# Goal
string gripper              # Gripper type: "hande", "epick"
string pick_approach        # Approach pose key for pick location
string pick_target          # Target pose key for pick location
string place_approach       # Approach pose key for place location
string place_target         # Target pose key for place location
string planning_type        # Planning method: "joint" or "cartesian"
string poses_json           # JSON string containing all poses from the task
---
# Result
bool success
string error_message
---
# Feedback
string current_operation   # "approaching", "grasping", "lifting", "placing", etc.
float32 progress_percentage
string current_pose       # Current pose being executed
string current_phase      # "pick", "transport", "place"
