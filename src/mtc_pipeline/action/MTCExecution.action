# Goal
string task_script_json    # JSON string containing only the tasks array and start_gripper
string poses_json          # JSON string containing the poses dictionary
string robot_ip            # Robot IP address (optional, can use default)
---
# Result
bool success
string error_message
int32 completed_steps
int32 total_steps
---
# Feedback
int32 current_step
string current_action
float32 progress_percentage
string status_message
string current_gripper
