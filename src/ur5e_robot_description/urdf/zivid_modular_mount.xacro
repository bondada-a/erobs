<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="zivid_modular_mount">

  <!-- Import official Zivid camera from zivid-ros -->
  <xacro:include filename="$(find zivid_description)/urdf/macros/zivid_camera.xacro"/>

  <xacro:macro name="zivid_modular_mount" params="parent_link xyz:='0 0 0' rpy:='0 0 0' zivid_model:='ZIVID_2_PLUS_MR60'">

    <!-- ============================================= -->
    <!-- ARM MOUNT LINK (Easily replaceable)          -->
    <!-- ============================================= -->
    <link name="zivid_arm_mount">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <!-- MOUNT MESH - Replace this when Zivid provides new model -->
          <mesh filename="package://ur5e_robot_description/meshes/zivid/zivid_onarm_mount.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="mount_dark">
          <color rgba="0.2 0.2 0.2 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur5e_robot_description/meshes/zivid/zivid_onarm_mount.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>  <!-- Approximate arm mount mass -->
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                 iyy="0.001" iyz="0.0"
                 izz="0.001"/>
      </inertial>
    </link>

    <!-- Joint: Flange -> Arm Mount -->
    <joint name="zivid_arm_mount_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="zivid_arm_mount"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <!-- ============================================= -->
    <!-- ZIVID CAMERA (From official zivid-ros)       -->
    <!-- ============================================= -->
    <xacro:zivid_camera
      prefix="zivid_"
      model="${zivid_model}"
      field_of_view="false"/>

    <!-- ============================================= -->
    <!-- Joint: Arm Mount -> Camera                   -->
    <!-- CALIBRATION: Adjust xyz/rpy to match setup   -->
    <!-- ============================================= -->
    <joint name="mount_to_camera_joint" type="fixed">
      <parent link="zivid_arm_mount"/>
      <child link="zivid_base_link"/>
      <!-- for forward mounted camera bracket -->
            <!-- <origin xyz="0.025 0.062 0.0" rpy="0 -1.5708 -1.5708"/> --> 
              
      <!-- for backward mounted camera bracket -->
      <origin xyz="0.025 0.062 -0.049" rpy="0 -1.5708 -1.5708"/>
      
    </joint>

  </xacro:macro>

</robot>
